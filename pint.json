{
    "preset": "laravel",
    "rules": {
        "declare_strict_types": false,
        "blank_line_before_statement": {
            "statements": ["return", "throw", "try"]
        },
        "concat_space": {
            "spacing": "one"
        },
        "ordered_imports": {
            "sort_algorithm": "alpha"
        },
        "single_quote": true,
        "no_unused_imports": true,
        "trailing_comma_in_multiline": {
            "elements": ["arrays", "arguments"]
        }
    },
    "exclude": [
        "vendor",
        "templates"
    ]
}
